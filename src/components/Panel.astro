---
const { title, eyebrow, description, class: className = '', ...rest } = Astro.props;
---

<section class={`panel overflow-hidden ${className}`} {...rest}>
  {(title || eyebrow || description) && (
    <div class="border-b border-white/10 px-5 py-4 sm:px-6">
      {eyebrow && <div class="chip mb-3 w-fit">{eyebrow}</div>}
      {title && <h2 class="text-xl font-bold tracking-tight text-white">{title}</h2>}
      {description && <p class="mt-2 max-w-3xl text-sm leading-6 text-white/65">{description}</p>}
    </div>
  )}
  <div class="px-5 py-5 sm:px-6 sm:py-6">
    <slot />
  </div>
</section>
