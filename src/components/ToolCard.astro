---
import type { ToolDefinition } from '../data/tools';

type ToolCardProps = {
  tool: ToolDefinition;
};

const { tool } = Astro.props as ToolCardProps;
const base = import.meta.env.BASE_URL;
const withBase = (path: string) => {
  const clean = path === '/' ? '' : path.replace(/^\//, '');
  return `${base}${clean}`;
};
---

<a href={withBase(tool.href)} class="group surface-panel block overflow-hidden p-6 transition duration-200 hover:-translate-y-1 hover:border-white/20 hover:bg-white/[0.04]">
  <div class="mb-4 flex items-center justify-between gap-3">
    <span class="chip">{tool.badge}</span>
    <span class="flex h-11 w-11 items-center justify-center rounded-2xl border border-white/10 bg-white/[0.04] text-xl text-white transition duration-200 group-hover:border-white/15 group-hover:bg-white/[0.06] group-hover:scale-105">
      {tool.icon}
    </span>
  </div>
  <h3 class="mb-2 text-2xl font-semibold tracking-tight text-white">{tool.title}</h3>
  <p class="max-w-xl text-sm leading-6 text-white/62">{tool.summary}</p>
  <div class="mt-5 flex items-center justify-between gap-3 border-t border-white/10 pt-4 text-[10px] uppercase tracking-[0.24em] text-white/42">
    <span>{tool.status}</span>
    <span class="transition duration-200 group-hover:text-white/85">Open</span>
  </div>
</a>
