---
const { label, value, hint, class: className = '' } = Astro.props;
---

<article class={`rounded-3xl border border-white/10 bg-white/[0.04] p-4 shadow-glow ${className}`}>
  <div class="field-label">{label}</div>
  <div class="mt-2 text-2xl font-black tracking-tight text-white sm:text-3xl">{value}</div>
  {hint && <p class="mt-2 text-sm leading-6 text-white/60">{hint}</p>}
</article>
