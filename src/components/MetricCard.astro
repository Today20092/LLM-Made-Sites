---
const { label, value, hint, class: className = '' } = Astro.props;
---

<article class={`surface-card p-4 ${className}`}>
  <div class="field-label">{label}</div>
  <div class="mt-2 text-2xl font-semibold tracking-tight text-white sm:text-3xl">{value}</div>
  {hint && <p class="mt-2 text-sm leading-6 text-white/58">{hint}</p>}
</article>
